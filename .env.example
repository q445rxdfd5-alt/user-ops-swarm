# =============================================================================
# User Ops Swarm — Environment Variables
# =============================================================================
# Copy this to .env and configure for your environment.
#
# Option A: Local Ollama (recommended for development — no API key needed)
#   1. Install Ollama: https://ollama.ai
#   2. Pull a model:  ollama pull llama3.2
#   3. Ollama runs automatically when accessed via http://localhost:11434
#
# Option B: OpenAI / Anthropic (for production-quality outputs)
#   1. Set your API key below
#   2. Update model in src/flow/user_ops_flow.py _get_llm()

# ── Ollama (local, default) ──────────────────────────────────────────────────
# No API key needed. Ensure Ollama is running: /usr/local/bin/ollama serve
# Optional: override default model
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Evaluation ────────────────────────────────────────────────────────────────
# EVALUATION_MODEL=gpt-4o   # model used for baseline comparison
